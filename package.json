{
  "name": "kaku",
  "version": "1.0.0",
  "description": "CJK character stroke animation library with pluggable data adapters",
  "type": "module",
  "main": "./dist/kaku.cjs",
  "module": "./dist/kaku.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/kaku.js",
      "require": "./dist/kaku.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "cjk",
    "kanji",
    "stroke",
    "animation",
    "kanjivg"
  ],
  "license": "MIT"
}
